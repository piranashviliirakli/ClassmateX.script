-- BUTTON FACTORY
local function CreateToggle(name, globalVar)
    local btn = Instance.new("TextButton", Scroll)
    btn.Size = UDim2.new(0.9, 0, 0, 45)
    btn.Text = name
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 14
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.BackgroundColor3 = Color3.fromRGB(150, 0, 0) -- Start Red
    local corner = Instance.new("UICorner", btn)

    local function UpdateColor()
        if _G[globalVar] then
            btn.BackgroundColor3 = Color3.fromRGB(0, 180, 0) -- Green
        else
            btn.BackgroundColor3 = Color3.fromRGB(150, 0, 0) -- Red
        end
    end

    btn.MouseButton1Click:Connect(function()
        _G[globalVar] = not _G[globalVar]
        UpdateColor()
    end)
    
    return btn
end

