-- [[ MAIN BRAINROT LOGIC ]] --
task.spawn(function()
    while task.wait() do
        pcall(function()
            local char = lp.Character
            if not char then return end

            -- 1. AUTO LOCK BASE (Closes Doors/Gates)
            if _G.ClassmateX_AutoLock then
                for _, obj in pairs(workspace:GetDescendants()) do
                    -- Checks for Prompts that say "Close" or "Lock"
                    if obj:IsA("ProximityPrompt") then
                        local txt = obj.ActionText:lower()
                        if txt:find("lock") or txt:find("close") or txt:find("shut") then
                            fireproximityprompt(obj)
                        end
                    end
                    -- Checks for ClickDetectors in the base
                    if obj:IsA("ClickDetector") and (obj.Parent.Name:lower():find("door") or obj.Parent.Name:lower():find("gate")) then
                        fireclickdetector(obj)
                    end
                end
            end

            -- 2. INSTA TAKE (Instant E)
            if _G.ClassmateX_InstaTake then
                for _, p in pairs(workspace:GetDescendants()) do
                    if p:IsA("ProximityPrompt") then
                        p.HoldDuration = 0
                        fireproximityprompt(p)
                    end
                end
            end

            -- 3. AUTO DUEL & WIN
            if _G.ClassmateX_AutoDuel or _G.ClassmateX_AutoWin then
                for _, g in pairs(lp.PlayerGui:GetDescendants()) do
                    if g:IsA("TextButton") and g.Visible and (g.Text:lower():find("click") or g.Text:lower():find("fight") or g.Text:lower():find("duel")) then
                        firesignal(g.MouseButton1Click)
                    end
                end
            end

            -- 4. MOVEMENT
            if char:FindFirstChild("Humanoid") then
                char.Humanoid.WalkSpeed = _G.ClassmateX_Speed
                if _G.ClassmateX_Noclip then
                    for _, v in pairs(char:GetDescendants()) do
                        if v:IsA("BasePart") then v.CanCollide = false end
                    end
                end
            end
        end)
    end
end)

